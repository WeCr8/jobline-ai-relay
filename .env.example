# JobLine Relay — copy to .env and fill in production values

PORT=4242
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# CHANGE in production — use: openssl rand -hex 64
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=30d

# Format: tenantId:apiKey,tenantId2:apiKey2
# Generate keys with: openssl rand -hex 32
PUBLISHER_KEYS=dev-tenant:dev-publisher-key

MAX_SUBSCRIBERS_PER_TENANT=50
MAX_PUBLISHERS_PER_TENANT=10
SNAPSHOT_TTL_MS=300000
PING_INTERVAL_MS=30000
MAX_MESSAGE_BYTES=256000

# Set to your dashboard domain in production: https://app.jobline.ai
CORS_ORIGINS=*
