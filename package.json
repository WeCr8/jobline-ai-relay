{
  "name": "@jobline/relay",
  "version": "1.0.0",
  "description": "JobLine.ai cloud relay — WebSocket event broker between VS Code and React Native dashboard",
  "main": "dist/server.js",
  "scripts": {
    "dev":   "npx tsx src/server.ts",
    "build": "npx tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test":  "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=relay.test"
  },
  "dependencies": {
    "ws":            "^8.17.0",
    "express":       "^4.19.0",
    "jsonwebtoken":  "^9.0.2",
    "uuid":          "^9.0.1",
    "dotenv":        "^16.4.5"
  },
  "devDependencies": {
    "@types/ws":           "^8.5.10",
    "@types/express":      "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/uuid":         "^9.0.8",
    "@types/node":         "^20.12.0",
    "@types/jest":         "^29.5.0",
    "typescript":          "^5.4.0",
    "tsx":                 "^4.10.0",
    "ts-jest":             "^29.1.0",
    "jest":                "^29.7.0"
  },
  "engines": { "node": ">=18" }
}
